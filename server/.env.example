# ===== Discord bot =====
DISCORD_BOT_TOKEN=            # from discord.com/developers
BOT_SHARED_SECRET=change-me-long-random   # must match BOT_SHARED_SECRET on the website
INGEST_URL=https://degenaration.vercel.app/api/ingest-call   # where the bot posts calls
CHANNELS_REFRESH_MS=30000     # how often the bot reloads approved channels from the DB
# Bot reads approved channels from the DB (call_channels) — no APPROVED_CHANNELS env needed.
# Also needs SUPABASE_URL + SUPABASE_SERVICE_KEY (below) to read channels / register new ones.

# ===== Trading engine =====
PLATFORM_FEE_ACCOUNT=         # YOUR wallet's fee token account — where the 2% goes
PORT=8787

# ===== Automation worker (limit orders + copy trading) =====
SUPABASE_URL=                 # your Supabase project URL
SUPABASE_SERVICE_KEY=         # service-role key (SERVER ONLY — never ship to client)
MAINNET_RPC=                  # paid RPC recommended (Helius/QuickNode) for reliability
WORKER_NET=mainnet            # mainnet only
DELEGATED_SIGNING=off         # set to "on" ONLY after a supervised tiny-amount signing test

# Privy delegated signing (worker signs for users who enabled 24/7 auto-trading)
PRIVY_APP_ID=
PRIVY_APP_SECRET=             # SERVER ONLY
PRIVY_AUTHORIZATION_KEY=      # wallet-API authorization private key (session signers)
